# an .env file used by ipv-core-stub when running locally in Docker

# JWT-signing EC private key
CORE_STUB_SIGNING_PRIVATE_KEY_JWK_

# the public key of above, used by CRIs to verify the JWT - here as a reference
CORE_STUB_SIGNING_PUBLIC_JWK={ "kty": "EC", "use": "sig", "crv": "P-256", "x": "k39uKacSukQBrMZrHDTBUZslivpXKDNZTg6inCHwrLc", "y": "8F8LnQ7wG9hxsT4ax0Aty7iMGIyiY_YGp3_qIZzKo1A", "alg": "ES256" }

# the CRIs available in ipv-core-stub when running locally in Docker
CORE_STUB_CONFIG_FILE=/app/config/cris-local-dev.yaml

# CRI APIs in the `dev` Environment are configured to expect this Authorization issuer
CORE_STUB_JWT_ISS_CRI_URI=https://cri.core.build.stubs.account.gov.uk

# Core stub client Id to use
CORE_STUB_CLIENT_ID=ipv-core-stub-aws-build

# API key 1 for the di-ipv-cri-dev account
API_KEY_CRI_DEV=vNcGwyTEkz6gMxP4pfASQ9IACaX3SkLq5WKqDpJc

# do not apply DOB aging
CORE_STUB_CONFIG_AGED_DOB=false
